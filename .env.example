# SUG Grappling — Environment Variables Template
#
# Copy this file to `.env.local` (preferred) or `.env` and fill in the
# values from your Supabase project: Project Settings → API.
#
# Expo only exposes variables prefixed with EXPO_PUBLIC_* to the JS bundle.
# Never commit real secrets — `.env` and `.env.local` are gitignored.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
